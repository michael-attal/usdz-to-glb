{
  "name": "usdz-to-glb",
  "version": "0.1.3",
  "description": "Convert Apple USDZ files (USDA + USDC) to GLB (binary GLTF 2.0) — pure JavaScript, no native dependencies",
  "keywords": [
    "usdz",
    "glb",
    "gltf",
    "usd",
    "usda",
    "usdc",
    "3d",
    "converter",
    "roomplan",
    "apple"
  ],
  "author": "energyi",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "usdz-to-glb": "bin/usdz-to-glb.js"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test test/**/*.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Uzithei/usdz-to-glb"
  },
  "dependencies": {
    "lz4js": "^0.2.0"
  }
}
